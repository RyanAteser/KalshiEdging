# ─────────────────────────────────────────────────────────────────────
#  Kalshi Sports Momentum Bot — .env
#  Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────

# ── Kalshi API ────────────────────────────────────────────────────────
KALSHI_API_KEY_ID= ###PRIVATE KEY
KALSHI_PRIVATE_KEY_PATH=./keys/prod_private_key.pem

KALSHI_API_BASE_URL=https://trading-api.kalshi.com
# ==============================================
# Database
# ==============================================
# SQLite (default — no setup required):
DATABASE_URL=

# PostgreSQL (optional):
# DATABASE_URL=postgresql://user:password@localhost:5432/kalshi_trader

# ==============================================
# EV Grid Filter strategy
# ==============================================
# Grid range: only trade when price is between these bounds
EV_GRID_MIN=0.50
EV_GRID_MAX=0.80

# EV thresholds — tune via backtesting
EV_MIN_ENTRY=0.005      # Minimum EV to open a position
EV_MIN_EXIT=0.010       # Auto-exit when EV drops below this (tuned via backtest)

# Fee approximation used in EV formula (Kalshi: ~0.07 × p × (1-p) per contract)
EV_FEE_RATE=0.007

# Legacy params (still loaded but not used by EV engine)
ENTRY_THRESHOLD=0.52
STOP_LOSS=0.46
MAX_SPREAD=0.08
POSITION_SIZE=1
PAPER_TRADE=True
LOG_LEVEL=INFO

